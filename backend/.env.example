# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/hermes?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Solana RPC
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
HELIUS_API_KEY="your-helius-api-key"
SOLANA_NETWORK="mainnet-beta"

# API Server
PORT=3000
NODE_ENV="development"

# Protocol API Keys (if needed)
MARINADE_API_KEY=""
JITO_API_KEY=""
MARGINFI_API_KEY=""
KAMINO_API_KEY=""
ORCA_API_KEY=""

# Jito Block Engine (jito-ts SDK)
JITO_BLOCK_ENGINE_URL="frankfurt.mainnet.block-engine.jito.wtf"
# Optional: Path to auth keypair for protected Jito Block Engine methods
# JITO_AUTH_KEYPAIR_PATH="./jito-auth-keypair.json"

# Risk Model Weights
RISK_WEIGHT_APY=0.4
RISK_WEIGHT_TVL=0.2
RISK_WEIGHT_VOLATILITY=0.25
RISK_WEIGHT_IL=0.1
RISK_WEIGHT_PROTOCOL=0.05

# DPO Settings
DPO_REBALANCE_THRESHOLD=0.15
DPO_MIN_YIELD_IMPROVEMENT=0.02
DPO_EVALUATION_INTERVAL_MINUTES=60

# Worker Settings
YIELD_COLLECTION_INTERVAL_MINUTES=10
DPO_WORKER_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL="info"
