// Prisma schema for HERMES

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Yield data from protocols
model YieldRecord {
  id            String   @id @default(cuid())
  protocol      String   // "marinade", "jito", "marginfi", "kamino", "orca"
  asset         String   // "SOL", "USDC", "SOL-USDC", etc.
  pool          String?  // Pool identifier for LP positions
  apy           Float    // Annual Percentage Yield
  apr           Float?   // Annual Percentage Rate (without compounding)
  tvl           Float    // Total Value Locked in USD
  riskScore     Float    // Calculated risk score (0-100)
  volatility    Float    // Historical volatility metric
  timestamp     DateTime @default(now())
  
  // Protocol-specific metrics
  metadata      Json?    // Store protocol-specific data
  
  // Risk metrics
  liquidationRisk Float? // For lending protocols
  impermanentLoss Float? // For LP positions
  
  @@index([protocol, asset, timestamp])
  @@index([timestamp])
  @@map("yield_records")
}

// User portfolio allocations
model Portfolio {
  id              String   @id @default(cuid())
  userId          String   @unique
  walletAddress   String
  allocations     Json     // { "marinade": { amount: 100, percentage: 0.5 }, ... }
  totalValue      Float    @default(0)
  riskProfile     String   // "conservative", "moderate", "aggressive"
  lastRebalance   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Performance tracking
  initialValue    Float?
  currentYield    Float?
  
  // Relations
  dpoJobs         DPOJob[]
  transactions    Transaction[]
  
  @@index([userId])
  @@index([walletAddress])
  @@map("portfolios")
}

// Dynamic Portfolio Orchestration jobs
model DPOJob {
  id            String   @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  action        String   // "rebalance", "allocate", "exit", "chase_yield"
  fromProtocol  String?
  toProtocol    String?
  amount        Float?
  reason        String   // Explanation for the action
  confidence    Float    // 0-1 confidence score
  
  status        String   @default("pending") // "pending", "executing", "completed", "failed"
  error         String?
  
  createdAt     DateTime @default(now())
  executedAt    DateTime?
  completedAt   DateTime?
  
  // Execution details
  txSignature   String?
  
  @@index([portfolioId, status])
  @@index([status, createdAt])
  @@map("dpo_jobs")
}

// Protocol metadata and health metrics
model ProtocolMetadata {
  id                String   @id @default(cuid())
  protocol          String   @unique
  name              String
  isActive          Boolean  @default(true)
  isBlacklisted     Boolean  @default(false)
  
  // Health metrics
  healthScore       Float    @default(100)
  lastSuccessfulFetch DateTime?
  consecutiveFailures Int    @default(0)
  
  // Risk factors
  auditScore        Float?   // Security audit score
  tvlRank           Int?
  ageInDays         Int?
  
  // Emission & Incentive Tracking
  hasEmissions      Boolean  @default(false)
  emissionSchedule  Json?    // { token, dailyRate, vestingEnd, totalRemaining }
  nextEmissionChange DateTime?
  incentivePrograms Json?    // Array of active incentive programs
  
  // API endpoints
  apiEndpoint       String?
  requiresAuth      Boolean  @default(false)
  
  updatedAt         DateTime @updatedAt
  
  @@map("protocol_metadata")
}

// Transaction history
model Transaction {
  id              String   @id @default(cuid())
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  type            String   // "deposit", "withdraw", "rebalance"
  protocol        String
  asset           String
  amount          Float
  
  txSignature     String   @unique
  status          String   // "pending", "confirmed", "failed"
  
  blockTime       DateTime?
  fee             Float?
  
  createdAt       DateTime @default(now())
  
  @@index([portfolioId, createdAt])
  @@index([txSignature])
  @@map("transactions")
}

// Volatility oracle data
model VolatilitySnapshot {
  id          String   @id @default(cuid())
  protocol    String
  asset       String
  
  // Volatility metrics
  volatility  Float    // Standard deviation of returns
  sharpeRatio Float?   
  maxDrawdown Float?
  
  // Time window
  timeWindow  String   // "24h", "7d", "30d"
  timestamp   DateTime @default(now())
  
  @@index([protocol, asset, timeWindow, timestamp])
  @@map("volatility_snapshots")
}

// Risk events log
model RiskEvent {
  id          String   @id @default(cuid())
  protocol    String
  eventType   String   // "apy_drop", "tvl_drop", "exploit", "high_volatility"
  severity    String   // "low", "medium", "high", "critical"
  description String
  metrics     Json?
  
  timestamp   DateTime @default(now())
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  
  @@index([protocol, timestamp])
  @@index([severity, resolved])
  @@map("risk_events")
}

// Funding rate tracking for perpetual protocols
model FundingRate {
  id              String   @id @default(cuid())
  protocol        String   // "drift", "zeta", "goosefx"
  market          String   // "SOL-PERP", "BTC-PERP", etc.
  fundingRate     Float    // Current hourly funding rate
  fundingRate8h   Float?   // 8-hour funding rate
  openInterest    Float?   // Total open interest in USD
  volume24h       Float?   // 24h trading volume
  
  timestamp       DateTime @default(now())
  
  @@index([protocol, market, timestamp])
  @@map("funding_rates")
}
