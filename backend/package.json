{
  "name": "backend",
  "version": "1.0.0",
  "description": "HERMES - Solana Meta-Yield Aggregator & Routing Engine",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--expose-gc --max-old-space-size=4096' npx tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "worker:yield": "tsx src/workers/yieldCollector.ts",
    "worker:dpo": "tsx src/workers/dpoWorker.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "solana",
    "defi",
    "yield",
    "aggregator",
    "routing"
  ],
  "author": "HERMES Team",
  "license": "MIT",
  "dependencies": {
    "@kamino-finance/klend-sdk": "^7.3.4",
    "@marinade.finance/native-staking-sdk": "^1.3.4",
    "@mrgnlabs/marginfi-client-v2": "^6.2.1",
    "@mrgnlabs/mrgn-common": "^2.0.7",
    "@orca-so/common-sdk": "^0.7.0",
    "@orca-so/whirlpools-sdk": "^0.17.0",
    "@prisma/client": "^5.7.0",
    "@solana/spl-token": "^0.3.9",
    "@solana/web3.js": "^1.87.6",
    "async": "3.2.6",
    "axios": "^1.6.2",
    "axios-retry": "^4.0.0",
    "bn.js": "^5.2.1",
    "bullmq": "^5.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "hasown": "^2.0.2",
    "helmet": "^7.1.0",
    "jito-ts": "^4.2.1",
    "redis": "^4.6.11",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@mrgnlabs/tsconfig": "^0.0.1",
    "@types/bn.js": "^5.2.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "schema": "src/db/schema.prisma"
  }
}
